#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")"
PORT="${1:-18080}"
if docker compose ps --status running --quiet 2>/dev/null | grep -q .; then
  echo "Clippy is already running."
  xdg-open "http://localhost:${PORT}" &>/dev/null &
else
  PORT="$PORT" docker compose up --build -d
  xdg-open "http://localhost:${PORT}" &>/dev/null &
fi
